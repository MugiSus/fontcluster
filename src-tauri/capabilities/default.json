{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "updater:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "process:allow-restart",
    "os:allow-locale"
  ]
}
