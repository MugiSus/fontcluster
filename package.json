{
  "name": "fontcluster",
  "version": "0.23.1",
  "description": "A font clustering and visualization tool powered by Tauri.",
  "author": "mugisus",
  "homepage": "https://fontcluster.mugisus.me",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "release": "cargo release --manifest-path src-tauri/Cargo.toml",
    "tauri": "tauri",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.node.json --noEmit",
    "check": "pnpm run typecheck && pnpm run lint && pnpm run format:check"
  },
  "license": "GPL-2.0-or-later",
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/noto-sans-jp": "^5.2.10",
    "@fontsource/geist": "^5.2.9",
    "@kobalte/core": "^0.13.10",
    "@solid-primitives/history": "^0.2.3",
    "@solid-primitives/i18n": "^2.2.1",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solid-primitives/storage": "^4.3.4",
    "@tanstack/solid-virtual": "^3.13.18",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-array": "^3.2.4",
    "d3-quadtree": "^3.0.1",
    "d3-scale": "^4.0.2",
    "fuse.js": "^7.1.0",
    "lucide-solid": "^0.525.0",
    "solid-js": "^1.9.3",
    "solid-sonner": "^0.2.8",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.184.0",
    "troika-three-text": "^0.52.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@tauri-apps/cli": "^2.11.0",
    "@types/d3-array": "^3.2.2",
    "@types/d3-quadtree": "^3.0.6",
    "@types/d3-scale": "^4.0.9",
    "@types/node": "^24.0.8",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.35.0",
    "@typescript-eslint/parser": "^8.35.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-no-relative-import-paths": "^1.6.1",
    "eslint-plugin-prettier": "^5.5.0",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-tailwindcss": "^3.18.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "postcss": "^8.5.6",
    "prettier": "^3.6.0",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.35.0",
    "vite": "^6.0.3",
    "vite-plugin-solid": "^2.11.0"
  }
}
